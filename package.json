{
  "name": "vinovault",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nodemon server/src/server.js",
    "dev:full": "concurrently -n API,Vite -c cyan,magenta \"tsx --watch scripts/dev-server.ts\" \"cd client && npm run dev\"",
    "dev:api": "tsx --watch scripts/dev-server.ts",
    "dev:client": "cd client && npm run dev",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "npm run lint:server && npm run lint:client",
    "lint:server": "eslint server scripts api lib tests/backend",
    "lint:client": "npm --prefix client run lint",
    "start": "node server/src/server.js",
    "scrape": "node scripts/scraper.js",
    "seed": "node scripts/seed.js",
    "monitor": "node scripts/monitor.js",
    "test": "jest --forceExit",
    "test:client": "npm --prefix client run test",
    "build:client": "npm --prefix client run build",
    "test:watch": "jest --watch"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/backend/**/*.test.js"
    ],
    "testTimeout": 30000
  },
  "dependencies": {
    "@clerk/backend": "^1.26.0",
    "@clerk/express": "^2.1.4",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "mongoose": "^9.4.1",
    "nodemailer": "^8.0.5",
    "socket.io": "^4.8.3",
    "svix": "^1.67.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "@vercel/node": "^5.3.2",
    "cheerio": "^1.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.10",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.59.0"
  }
}
